# ===========================================
# 银龄乐圈后端环境配置
# ===========================================
# 复制此文件为 .env 并填写实际值
# cp .env.example .env

# ============ 应用配置 ============
PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000

# ============ 数据库配置 ============
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_password
DB_DATABASE=yinling_db

# ============ JWT 配置 ============
# 生成密钥命令：openssl rand -base64 32
JWT_SECRET=your_jwt_secret_key_here_min_32_chars
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here_min_32_chars

# ============ 微信登录配置 ============
# 在微信公众平台获取：https://mp.weixin.qq.com
# 测试号：https://mp.weixin.qq.com/debug/cgi-bin/sandboxinfo
WECHAT_APPID=your_wechat_appid
WECHAT_SECRET=your_wechat_secret

# ============ 文件上传配置 ============

# 方式一：本地存储（简单，适合开发）
UPLOAD_DIR=./uploads

# 方式二：阿里云 OSS（生产环境推荐）
# 1. 安装 SDK：npm install ali-oss
# 2. 在阿里云控制台创建 Bucket
# 3. 填写以下配置
# OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
# OSS_REGION=cn-hangzhou
# OSS_ACCESS_KEY_ID=your_access_key_id
# OSS_ACCESS_KEY_SECRET=your_access_key_secret
# OSS_BUCKET=your_bucket_name

# ============ 数据库配置（替代方案：MySQL） ============
# 如果使用 MySQL，取消下面的注释
# DB_TYPE=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_USERNAME=root
# DB_PASSWORD=your_password
# DB_DATABASE=yinling_db
